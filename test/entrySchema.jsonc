        "stats": {
            "admins": 2, // Total ADMINS including the OWNER
            "entries": {
                "sysEntries": 0, // System Entries, because every action is an entry
                "datEntries": 3 // Data Entries, responsible for contributing to the data
            },
            "subjects": {
                "activeSubs": 3, // Who are still currently maintained
                "deadSubs": 0 // Who are removed or not maintained, but exist in the history
            }
        },
        "createdAt": 1778936526728, // When the file was created for teh first time
        "modifiedAt": 1778936529437 // Every time a change happens in this file, legally
    },


